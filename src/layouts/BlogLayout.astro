---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
}

const { title, description, date, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${title} — Mohamed Erfan`} description={description}>
  <main id="main" class="relative pt-32 pb-24">
    <div class="container-narrow">
      <a
        href="/blog"
        class="inline-flex items-center gap-1.5 text-sm text-ink-500 dark:text-ink-400 hover:text-accent transition-colors duration-200 mb-10"
      >
        ← Back to blog
      </a>

      <header class="mb-12">
        <p class="section-eyebrow mb-4">Blog</p>
        <h1 class="font-display text-display-lg font-semibold tracking-tight text-balance mb-4">
          {title}
        </h1>
        <p class="text-ink-600 dark:text-ink-300 text-lg mb-6">{description}</p>
        <div class="flex flex-wrap items-center gap-4 text-sm text-ink-500 dark:text-ink-400">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          {tags.length > 0 && (
            <ul class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <li class="chip">{tag}</li>
              ))}
            </ul>
          )}
        </div>
      </header>

      <div class="prose dark:prose-invert max-w-none">
        <slot />
      </div>
    </div>
  </main>
</Layout>
