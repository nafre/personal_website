---
import Layout from './Layout.astro'
import { Icon } from 'astro-icon/components'

interface Props {
  title: string
  description: string
  date: Date
  tags: string[]
}

const { title, description, date, tags } = Astro.props

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date)
---

<Layout title={`${title} — Mohamed Erfan`} description={description}>
  <div class="mx-auto max-w-2xl px-6 py-24">
    <a
      href="/blog"
      class="inline-flex items-center gap-2 text-sm text-[--color-muted] hover:text-[--color-accent] transition-colors mb-12 group"
    >
      <Icon
        name="mdi:arrow-left"
        class="w-4 h-4 transition-transform group-hover:-translate-x-1"
      />
      Back to blog
    </a>

    <article>
      <header class="mb-12">
        <div class="flex flex-wrap gap-2 mb-4">
          {tags.map((tag) => (
            <span class="chip">{tag}</span>
          ))}
        </div>
        <h1
          class="text-3xl font-bold tracking-tight mb-4"
          style="color: var(--color-text);"
        >
          {title}
        </h1>
        <p class="text-sm" style="color: var(--color-muted);">
          {formattedDate}
        </p>
      </header>

      <div class="prose prose-lg">
        <slot />
      </div>
    </article>
  </div>
</Layout>
