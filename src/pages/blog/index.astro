---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function slugFromId(id: string) {
  return id.replace(/\.(md|mdx)$/, '');
}
---

<Layout
  title="Blog — Mohamed Erfan"
  description="Writing on backend engineering, distributed systems, and software craft."
>
  <main id="main" class="relative pt-32 pb-24">
    <div class="container-narrow">
      <p class="section-eyebrow" data-reveal>Blog</p>
      <h1
        class="mt-4 font-display text-display-lg font-semibold tracking-tight text-balance"
        data-reveal
        data-reveal-delay="50"
      >
        Writing & thinking.
      </h1>
      <p
        class="mt-4 text-ink-600 dark:text-ink-300"
        data-reveal
        data-reveal-delay="100"
      >
        Notes on backend engineering, distributed systems, and software craft.
      </p>

      {
        posts.length === 0 ? (
          <p class="mt-16 text-ink-500 dark:text-ink-400" data-reveal data-reveal-delay="150">
            No posts yet — check back soon.
          </p>
        ) : (
          <ul class="mt-14 space-y-6">
            {posts.map((post, i) => (
              <li data-reveal data-reveal-delay={String(i * 60)}>
                <a
                  href={`/blog/${slugFromId(post.id)}`}
                  class="group card block hover:-translate-y-1 hover:shadow-glow-accent dark:hover:shadow-glow-accent-dark transition-all duration-300"
                >
                  <div class="flex flex-col gap-2 sm:flex-row sm:items-baseline sm:justify-between">
                    <h2 class="text-lg font-semibold tracking-tight group-hover:text-accent transition-colors duration-200">
                      {post.data.title}
                    </h2>
                    <time
                      datetime={post.data.date.toISOString()}
                      class="shrink-0 text-xs uppercase tracking-[0.18em] text-ink-500 dark:text-ink-400"
                    >
                      {post.data.date.toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'short',
                        day: 'numeric',
                      })}
                    </time>
                  </div>
                  <p class="mt-2 text-sm text-ink-600 dark:text-ink-300 line-clamp-2">
                    {post.data.description}
                  </p>
                  {post.data.tags.length > 0 && (
                    <ul class="mt-4 flex flex-wrap gap-2">
                      {post.data.tags.map((tag) => (
                        <li class="chip">{tag}</li>
                      ))}
                    </ul>
                  )}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </main>
</Layout>
