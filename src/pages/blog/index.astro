---
import { getCollection } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import { Icon } from 'astro-icon/components'

const allPosts = await getCollection('blog', ({ data }) => !data.draft)
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

const readingTimes = new Map(
  posts.map((post) => {
    const words = post.body.split(/\s+/).filter(Boolean).length
    return [post.id, Math.max(1, Math.ceil(words / 200))]
  })
)
---

<Layout
  title="Blog — Mohamed Erfan"
  description="Writing on backend engineering, distributed systems, and lessons from production."
>
  <div style="max-width: 72rem; margin: 0 auto; padding: 5rem 1.5rem;">
    <div style="max-width: 48rem;">
      <a
        href="/"
        style="display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: var(--color-muted); text-decoration: none; margin-bottom: 3rem; transition: color 0.2s;"
        class="back-home group"
      >
        <Icon
          name="mdi:arrow-left"
          style="width: 1rem; height: 1rem; transition: transform 0.2s;"
          class="group-hover:-translate-x-1"
        />
        Back home
      </a>

      <span class="section-label">Blog</span>
      <div style="display: flex; align-items: baseline; gap: 0.75rem; margin-bottom: 0.5rem;">
        <h1 style="font-size: clamp(1.75rem, 3vw, 2rem); font-weight: 700; letter-spacing: -0.02em; color: var(--color-text); margin: 0;">
          Writing
        </h1>
        <span style="font-size: 0.8125rem; color: var(--color-subtle);">
          {posts.length} {posts.length === 1 ? 'post' : 'posts'}
        </span>
      </div>
      <p style="color: var(--color-muted); margin-bottom: 2.5rem; font-size: 1rem; line-height: 1.75;">
        On backend engineering, distributed systems, and the occasional lesson
        learned the hard way in production.
      </p>

      {posts.length === 0 && (
        <p style="color: var(--color-subtle); font-size: 0.9375rem;">
          No posts yet. Check back soon.
        </p>
      )}

      <div style="display: flex; flex-direction: column; gap: 0.75rem;">
        {posts.map((post, index) => {
          const date = new Intl.DateTimeFormat('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          }).format(post.data.date)
          const rt = readingTimes.get(post.id) ?? 1

          return (
            <a
              href={`/blog/${post.id}`}
              class="blog-card"
              style={`animation-delay: ${index * 0.07}s`}
            >
              <p class="blog-card-meta">
                <time>{date}</time>
                <span aria-hidden="true">·</span>
                <span>{rt} min read</span>
              </p>

              <h2 class="blog-card-title">{post.data.title}</h2>

              <p class="blog-card-desc">{post.data.description}</p>

              <div class="blog-card-footer">
                {post.data.tags.length > 0 && (
                  <div style="display: flex; flex-wrap: wrap; gap: 0.375rem;">
                    {post.data.tags.map((tag: string) => (
                      <span class="chip">{tag}</span>
                    ))}
                  </div>
                )}
                <span class="blog-card-cta">Read →</span>
              </div>
            </a>
          )
        })}
      </div>
    </div>
  </div>
</Layout>

<style>
  .back-home:hover {
    color: var(--color-accent);
  }
  .back-home:hover svg {
    transform: translateX(-3px);
  }

  .blog-card {
    display: block;
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background-color: var(--color-surface);
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease, background-color 0.2s ease;
    animation: blogFadeUp 0.45s ease both;
  }
  .blog-card:hover {
    border-color: color-mix(in srgb, var(--color-accent) 40%, var(--color-border));
    box-shadow: 0 8px 24px -4px color-mix(in srgb, var(--color-accent) 12%, transparent);
    transform: translateY(-2px);
    background-color: var(--color-bg);
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--color-subtle);
    margin: 0 0 0.625rem;
  }

  .blog-card-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
    margin: 0 0 0.375rem;
    transition: color 0.2s ease;
  }
  .blog-card:hover .blog-card-title {
    color: var(--color-accent);
  }

  .blog-card-desc {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0 0 1rem;
  }

  .blog-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .blog-card-cta {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent);
    white-space: nowrap;
    flex-shrink: 0;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .blog-card:hover .blog-card-cta {
    opacity: 1;
  }

  @keyframes blogFadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
