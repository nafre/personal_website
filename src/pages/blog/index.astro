---
import { getCollection } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import { Icon } from 'astro-icon/components'

const allPosts = await getCollection('blog', ({ data }) => !data.draft)
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
---

<Layout
  title="Blog — Mohamed Erfan"
  description="Writing on backend engineering, distributed systems, and lessons from production."
>
  <div style="max-width: 72rem; margin: 0 auto; padding: 5rem 1.5rem;">
    <div style="max-width: 42rem;">
      <a
        href="/"
        style="display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: var(--color-muted); text-decoration: none; margin-bottom: 3rem; transition: color 0.2s;"
        class="group"
      >
        <Icon
          name="mdi:arrow-left"
          style="width: 1rem; height: 1rem; transition: transform 0.2s;"
          class="group-hover:-translate-x-1"
        />
        Back home
      </a>

      <span class="section-label">Blog</span>
      <h1
        style="font-size: clamp(1.75rem, 3vw, 2rem); font-weight: 700; letter-spacing: -0.02em; color: var(--color-text); margin-bottom: 0.5rem;"
      >
        Writing
      </h1>
      <p style="color: var(--color-muted); margin-bottom: 3rem; font-size: 1rem; line-height: 1.75;">
        On backend engineering, distributed systems, and the occasional lesson
        learned the hard way in production.
      </p>

      {posts.length === 0 && (
        <p style="color: var(--color-subtle); font-size: 0.9375rem;">
          No posts yet. Check back soon.
        </p>
      )}

      <ol style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0;">
        {posts.map((post) => {
          const date = new Intl.DateTimeFormat('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          }).format(post.data.date)

          return (
            <li>
              <a
                href={`/blog/${post.id}`}
                style="display: block; padding: 1.5rem 0; border-bottom: 1px solid var(--color-border); text-decoration: none; transition: none;"
                class="blog-row"
              >
                <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap;">
                  <div>
                    <p
                      style="font-size: 1rem; font-weight: 600; color: var(--color-text); letter-spacing: -0.01em; margin-bottom: 0.375rem; transition: color 0.2s;"
                      class="blog-title"
                    >
                      {post.data.title}
                    </p>
                    <p style="font-size: 0.875rem; color: var(--color-muted); line-height: 1.5;">
                      {post.data.description}
                    </p>
                    {post.data.tags.length > 0 && (
                      <div style="display: flex; flex-wrap: wrap; gap: 0.375rem; margin-top: 0.75rem;">
                        {post.data.tags.map((tag: string) => (
                          <span class="chip">{tag}</span>
                        ))}
                      </div>
                    )}
                  </div>
                  <span style="font-size: 0.8125rem; color: var(--color-subtle); white-space: nowrap; margin-top: 0.125rem;">
                    {date}
                  </span>
                </div>
              </a>
            </li>
          )
        })}
      </ol>
    </div>
  </div>
</Layout>

<style>
  .blog-row:hover .blog-title {
    color: var(--color-accent);
  }
  .group:hover {
    color: var(--color-accent);
  }
  .group:hover svg {
    transform: translateX(-3px);
  }
</style>
