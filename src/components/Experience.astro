---
import { experience } from '../data/content.js';
---

<section id="experience" aria-labelledby="experience-heading" class="relative py-24 sm:py-32">
  <div class="container-narrow">
    <p class="section-eyebrow" data-reveal>Experience</p>
    <h2
      id="experience-heading"
      class="mt-4 max-w-2xl font-display text-display-lg font-semibold tracking-tight text-balance"
      data-reveal
      data-reveal-delay="50"
    >
      Where I've built things.
    </h2>

    <ol class="timeline">
      {experience.map((item: any, i: number) => (
        <li class="relative pl-8 pb-10 last:pb-0" data-reveal data-reveal-delay={String(i * 50)}>
          <span
            aria-hidden="true"
            class="absolute left-0 top-1.5 inline-flex h-3 w-3 -translate-x-1/2 items-center justify-center rounded-full border-2 border-white bg-accent dark:border-ink-900"
            style="box-shadow: 0 0 0 3px rgba(var(--color-accent-rgb), 0.2)"
          ></span>
          <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
            <h3 class="text-base font-medium tracking-tight">
              <span class="text-ink-900 dark:text-ink-50">{item.role}</span>
              <span class="mx-2 text-ink-300 dark:text-ink-600">·</span>
              <span class="text-ink-600 dark:text-ink-300">{item.company}</span>
            </h3>
            <span class="text-xs uppercase tracking-[0.18em] text-ink-500 dark:text-ink-400">
              {item.period}
            </span>
          </div>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-ink-600 dark:text-ink-300">
            {item.summary}
          </p>
        </li>
      ))}
    </ol>
  </div>
</section>
