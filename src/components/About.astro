---
import { site, experience } from '../data/content.js';
---

<section id="about" aria-labelledby="about-heading" class="relative py-24 sm:py-32">
  <div class="container-narrow">
    <p class="section-eyebrow" data-reveal>About</p>
    <h2
      id="about-heading"
      class="mt-4 max-w-2xl font-display text-display-lg font-semibold tracking-tight text-balance"
      data-reveal
      data-reveal-delay="50"
    >
      How I work, and what I care about.
    </h2>

    <div class="mt-12 grid gap-12 md:grid-cols-5">
      <div
        class="md:col-span-3 space-y-5 text-ink-600 dark:text-ink-300"
        data-reveal
        data-reveal-delay="100"
      >
        {site.longBio.map((p: string) => (
          <p class="text-lg leading-relaxed text-pretty">{p}</p>
        ))}
      </div>

      <div class="md:col-span-2" data-reveal data-reveal-delay="200">
        {site.photo && (
          <div class="mb-6 flex justify-center md:justify-start">
            <div class="relative h-36 w-36">
              <div class="absolute inset-0 rounded-full bg-gradient-to-br from-accent to-violet-500 p-0.5">
                <div class="h-full w-full rounded-full bg-white dark:bg-ink-900"></div>
              </div>
              <img
                src={site.photo}
                alt={site.name}
                loading="lazy"
                decoding="async"
                class="absolute inset-0.5 h-[calc(100%-4px)] w-[calc(100%-4px)] rounded-full object-cover object-top opacity-0 transition-opacity duration-300"
                onload="this.style.opacity='1'"
              />
            </div>
          </div>
        )}
        <dl class="card space-y-4 bg-white/60 backdrop-blur-sm dark:bg-ink-800/40">
          {[
            { k: 'Based in', v: site.location },
            { k: 'Focus', v: site.focus },
            { k: 'Currently', v: experience[0].role + ' at ' + experience[0].company },
            { k: 'Email', v: site.email, href: site.socials.email },
          ].map((row) => (
            <div class="flex items-baseline justify-between gap-4 border-b border-ink-100 pb-4 last:border-b-0 last:pb-0 dark:border-ink-800">
              <dt class="text-xs uppercase tracking-[0.18em] text-ink-500 dark:text-ink-400">
                {row.k}
              </dt>
              <dd class="text-right text-sm text-ink-900 dark:text-ink-100">
                {row.href ? (
                  <a class="link-subtle text-ink-900 dark:text-ink-100" href={row.href}>
                    {row.v}
                  </a>
                ) : (
                  row.v
                )}
              </dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </div>
</section>
