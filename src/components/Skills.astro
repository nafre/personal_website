---
import { skills } from '../data/content.js';
---

<section id="skills" aria-labelledby="skills-heading" class="relative py-24 sm:py-32">
  <div class="container-wide">
    <p class="section-eyebrow" data-reveal>Skills</p>
    <h2
      id="skills-heading"
      class="mt-4 max-w-2xl font-display text-display-lg font-semibold tracking-tight text-balance"
      data-reveal
      data-reveal-delay="50"
    >
      Tools I reach for.
    </h2>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {skills.map((group: any, i: number) => (
        <div class="card h-full hover:-translate-y-1 hover:shadow-glow-accent dark:hover:shadow-glow-accent-dark" data-reveal data-reveal-delay={String(i * 60)}>
          <h3 class="text-sm font-medium uppercase tracking-[0.18em] text-ink-500 dark:text-ink-400">
            {group.group}
          </h3>
          <ul class="mt-5 flex flex-wrap gap-2">
            {group.items.map((s: string) => (
              <li class="rounded-lg border border-ink-100 bg-ink-50/60 px-2.5 py-1 text-xs text-ink-800 transition-colors duration-200 hover:border-accent hover:text-accent dark:border-ink-700 dark:bg-ink-800/60 dark:text-ink-100 dark:hover:text-accent-soft">
                {s}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
